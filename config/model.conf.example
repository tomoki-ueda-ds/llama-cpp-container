###############################################################################
# llama-cpp-container
#
# Copy this file to:
#
#   ~/.config/llama-cpp-container/model.conf
#
###############################################################################

###############################################################################
# Model
###############################################################################

# Absolute path to the GGUF model inside the container.
#
# Example:
#
# MODEL=/models/Qwen3.6-35B-A3B/Qwen3.6-35B-A3B-Q8_0.gguf
#
MODEL=/models/<MODEL_DIRECTORY>/<MODEL_NAME>.gguf

###############################################################################
# Compute node
###############################################################################

# Hostname of the compute node running llama-server.
#
# Example:
# gpu001
#
LLM_SERVER_HOST=<GPU_NODE_HOSTNAME>

###############################################################################
# llama-server
###############################################################################

LLM_SERVER_PORT=18000

OPENAI_API_BASE=http://${LLM_SERVER_HOST}:${LLM_SERVER_PORT}/v1

OPENAI_API_KEY=dummy

###############################################################################
# Open WebUI
###############################################################################

OPENWEBUI_HOST=0.0.0.0

OPENWEBUI_PORT=3000